{
  "name": "vscode-nolang",
  "displayName": "Nolang Language Support",
  "description": "Nolang language support for Visual Studio Code",
  "version": "0.1.70",
  "icon": "icon.png",
  "publisher": "lizongying",
  "repository": {
    "type": "git",
    "url": "https://github.com/lizongying/nolang"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "main": "./client/out/extension",
  "activationEvents": [
    "onLanguage:nolang"
  ],
  "contributes": {
    "languages": [
      {
        "id": "nolang",
        "aliases": [
          "Nolang",
          "nolang"
        ],
        "extensions": [
          ".no"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "dark": "./icon16x16.png",
          "light": "./icon16x16.png"
        },
        "mimetypes": [
          "text/x-nolang"
        ]
      }
    ],
    "grammars": [
      {
        "language": "nolang",
        "scopeName": "source.nolang",
        "path": "./syntaxes/nolang.tmLanguage.json"
      },
      {
        "scopeName": "inject.nolang.md",
        "path": "./syntaxes/md-nolang-inject.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.nolang": "nolang"
        }
      }
    ],
    "configurationDefaults": {
      "[nolang]": {
        "editor.defaultFormatter": "lizongying.vscode-nolang",
        "editor.formatOnSave": true
      }
    },
    "configuration": {
      "type": "object",
      "title": "Nolang",
      "properties": {
        "nolang.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Path to the Nolang language server executable"
        },
        "nolang.languageServer.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for the language server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p client/tsconfig.json",
    "watch": "tsc -watch -p client/tsconfig.json",
    "package": "vsce package --out ../bin/",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.6.0",
    "typescript": "^5.0.0",
    "vsce": "^2.0.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}