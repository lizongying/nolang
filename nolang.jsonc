{
  // Nolang 项目配置文件
  "name": "nolang",
  "version": "0.1.0",
  "description": "A Nolang project",
  "workspace": "./src",
  // 依赖声明
  "dependencies": {
    // 标准库（版本号可省略或使用 "*"）
    "fmt": "*",
    "math": "*",
    "strconv": "*",
    // 第三方库（指定版本）
    "github.com/user/utils": "1.0.0"
  },
  // 编译配置
  "compiler": {
    "target": "go",
    "output": "./dist"
  }
}