// test_str_concat.no — String concatenation with - operator

// Test 1: String literal assignment and print
print('Hello World')

// Test 2: String variable assignment and print
s = 'Nolang'
print(s)

// Test 3: String concatenation with literals
greeting = 'Hello' - ' ' - 'World'
print(greeting)

// Test 4: String concatenation with variables
a = 'foo'
b = 'bar'
c = a - b
print(c)

// Test 5: Mixed concatenation
x = 'Hello'
y = x - ' ' - 'Nolang'
print(y)
