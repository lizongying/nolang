// ✅ match 语句：分支体是代码块
x {
    1|
        a = 1
        b = 2
        // 多行，不返回值
    2|
        do-something()
    |
        c = 0
}

// ✅ match 表达式：分支体是单一表达式
result = x {
    1| 1       // 单一值
    2| 2+1     //簡單表達式
    | a+b
}


// 特殊match
{
    a == 1|
        a = 1
        b = 2
        // 多行，不返回值
    a == 2|
        do-something()
    |
        c = 0
}

// 判讀返回值可能有錯的情況
x {
    err| log(.)
    nil| log('nil')
    |
        do-right-thing()
}