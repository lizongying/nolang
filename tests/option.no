// ../dist/match

// ✅ match 语句：分支是代码块

x = 3
x {
    1|
        print(11)
    2|
        print(22)
    |
        print(33)
}

x = 4
x {
    1| print(111)
    2| print(222)
    | print(333)
}


// ✅ match 表达式：分支体是单一表达式
a = 100
b = 101
result = x {
    1| 1       // 单一值
    2| 2+1     //簡單表達式
    | a+b
}
print(result)

