// Test 1: Declare and set nil
test-option-1 = () {
    x ?str
    x = nil
    println-i64(x)
}

// Test 2: Set value via val()
test-option-2 = () {
    x ?str
    x = val('hello')
    println-i64(x)
}

// Test 3: Set error
test-option-3 = () {
    x ?str
    x = err('error msg')
    println-i64(x)
}

// Test 4: Match on option with err-> nil-> -> patterns
test-option-4 = () {
    x ?str
    x = err('error msg')
    x {
        err ->
            println-i64(.)
        nil ->
            println-i64(0)
        ->
            println-i64(1)
    }
}

// Test 5: Match on nil
test-option-5 = () {
    x ?str
    x = nil
    x {
        err ->
            println-i64(100)
        nil ->
            println-i64(200)
        ->
            println-i64(300)
    }
}

// Test 6: Match on val
test-option-6 = () {
    x ?str
    x = val('test')
    x {
        err ->
            println-i64(1000)
        nil ->
            println-i64(2000)
        ->
            println-i64(3000)
    }
}

test-option-1()
println-i64(0)
test-option-2()
println-i64(1)
test-option-3()
println-i64(2)
test-option-4()
println-i64(3)
test-option-5()
println-i64(4)
test-option-6()
println-i64(5)
