// test_std_hash.no — 標準庫 hash 模組測試
//
// 輸出 KEY=VALUE 格式，與 tests/compare/compare.go 一致。
// 執行：nolang run tests/test_std_hash.no > tests/nolang-output.txt
// 比對：diff tests/compare/go-output.txt tests/nolang-output.txt

# std/hash/crc-32
# std/hash/fnv-1a-32
# std/hash/md5
# std/hash/sha256
# std/hash/sha512
# std/hash/aes-128-enc
# std/hash/aes-128-dec
# std/hash/des-enc
# std/hash/des-dec
# std/hash/rand
# std/hash/rand-str

// ═══════════════════════════════════════════
// CRC32
// ═══════════════════════════════════════════

// crc32("")=00000000
crc-32('', 0)(h)
fmt.print('crc32("")=')
fmt.print-hex32(h)
fmt.print('')

// crc32("hello")=3610a686
crc-32('hello', 5)(h)
fmt.print('crc32("hello")=')
fmt.print-hex32(h)
fmt.print('')

// crc32("fox")=414fa339
s = 'The quick brown fox jumps over the lazy dog'
crc-32(s, 43)(h)
fmt.print('crc32("fox")=')
fmt.print-hex32(h)
fmt.print('')

// ═══════════════════════════════════════════
// FNV-1a-32
// ═══════════════════════════════════════════

// fnv1a32("")=811c9dc5
fnv-1a-32('', 0)(h)
fmt.print('fnv1a32("")=')
fmt.print-hex32(h)
fmt.print('')

// fnv1a32("hello")=4f9f2cab
fnv-1a-32('hello', 5)(h)
fmt.print('fnv1a32("hello")=')
fmt.print-hex32(h)
fmt.print('')

// fnv1a32("fox")=048fff90
fnv-1a-32(s, 43)(h)
fmt.print('fnv1a32("fox")=')
fmt.print-hex32(h)
fmt.print('')

// ═══════════════════════════════════════════
// SHA-256（zero block 壓縮測試）
// ═══════════════════════════════════════════

block256 = make-str-16()
i = 0
for i < 16 {
    block256[i] = 0
    i = i + 1
}

// sha256-zero-block=da5698be17b9b46962335799779fbeca8ce5d491c0d26243bafef9ea1837a9d8
h0 = 1779033703; h1 = 3144134277; h2 = 1013904242; h3 = 2773480762
h4 = 1359893119; h5 = 2600822924; h6 = 528734635;  h7 = 1541459225
sha256(block256, 16)(h0, h1, h2, h3, h4, h5, h6, h7)

fmt.print('sha256-zero-block=')
fmt.print-hex32(h0); fmt.print-hex32(h1); fmt.print-hex32(h2); fmt.print-hex32(h3)
fmt.print-hex32(h4); fmt.print-hex32(h5); fmt.print-hex32(h6); fmt.print-hex32(h7)
fmt.print('')

// ═══════════════════════════════════════════
// SHA-256（空字串填充區塊）
// ═══════════════════════════════════════════

block256empty = make-str-16()
block256empty[0] = 2147483648  // 0x80000000
i = 1
for i < 16 {
    block256empty[i] = 0
    i = i + 1
}

h0 = 1779033703; h1 = 3144134277; h2 = 1013904242; h3 = 2773480762
h4 = 1359893119; h5 = 2600822924; h6 = 528734635;  h7 = 1541459225
sha256(block256empty, 16)(h0, h1, h2, h3, h4, h5, h6, h7)

fmt.print('sha256-empty=')
fmt.print-hex32(h0); fmt.print-hex32(h1); fmt.print-hex32(h2); fmt.print-hex32(h3)
fmt.print-hex32(h4); fmt.print-hex32(h5); fmt.print-hex32(h6); fmt.print-hex32(h7)
fmt.print('')

// ═══════════════════════════════════════════
// SHA-256（"abc" 填充區塊）
// ═══════════════════════════════════════════

block256abc = make-str-16()
block256abc[0] = 1633837952  // 0x61626380
i = 1
for i < 15 {
    block256abc[i] = 0
    i = i + 1
}
block256abc[15] = 24  // 0x18

h0 = 1779033703; h1 = 3144134277; h2 = 1013904242; h3 = 2773480762
h4 = 1359893119; h5 = 2600822924; h6 = 528734635;  h7 = 1541459225
sha256(block256abc, 16)(h0, h1, h2, h3, h4, h5, h6, h7)

fmt.print('sha256-abc=')
fmt.print-hex32(h0); fmt.print-hex32(h1); fmt.print-hex32(h2); fmt.print-hex32(h3)
fmt.print-hex32(h4); fmt.print-hex32(h5); fmt.print-hex32(h6); fmt.print-hex32(h7)
fmt.print('')

// ═══════════════════════════════════════════
// SHA-512（zero block 壓縮測試）
// ═══════════════════════════════════════════

block512 = make-str-16()
i = 0
for i < 16 {
    block512[i] = 0
    i = i + 1
}

// sha512-zero-block=cf7881d5774acbe8533362e0fbc780700267639d87460eda3086cb40e85931b0717dc95288a023a396bab2c14ce0b5e06fc4fe04eae33e0b91f4d80cbd668bee
h0 = 7640891576956012808;  h1 = -4942790177534073029
h2 = 4354685564936845355;  h3 = -6534734903238641935
h4 = 5840696475078001361;  h5 = -7276294671716946913
h6 = 2270897969802886507;  h7 = 6620516959819538809
sha512(block512, 16)(h0, h1, h2, h3, h4, h5, h6, h7)

fmt.print('sha512-zero-block=')
fmt.print-hex64(h0); fmt.print-hex64(h1); fmt.print-hex64(h2); fmt.print-hex64(h3)
fmt.print-hex64(h4); fmt.print-hex64(h5); fmt.print-hex64(h6); fmt.print-hex64(h7)
fmt.print('')

// ═══════════════════════════════════════════
// SHA-512（空字串填充區塊）
// ═══════════════════════════════════════════

block512empty = make-str-16()
block512empty[0] = -9223372036854775808  // 0x8000000000000000 (signed)
i = 1
for i < 16 {
    block512empty[i] = 0
    i = i + 1
}

h0 = 7640891576956012808;  h1 = -4942790177534073029
h2 = 4354685564936845355;  h3 = -6534734903238641935
h4 = 5840696475078001361;  h5 = -7276294671716946913
h6 = 2270897969802886507;  h7 = 6620516959819538809
sha512(block512empty, 16)(h0, h1, h2, h3, h4, h5, h6, h7)

fmt.print('sha512-empty=')
fmt.print-hex64(h0); fmt.print-hex64(h1); fmt.print-hex64(h2); fmt.print-hex64(h3)
fmt.print-hex64(h4); fmt.print-hex64(h5); fmt.print-hex64(h6); fmt.print-hex64(h7)
fmt.print('')

// ═══════════════════════════════════════════
// SHA-512（"abc" 填充區塊）
// ═══════════════════════════════════════════

block512abc = make-str-16()
block512abc[0] = 7020623177855533056  // 0x6162638000000000
i = 1
for i < 15 {
    block512abc[i] = 0
    i = i + 1
}
block512abc[15] = 24

h0 = 7640891576956012808;  h1 = -4942790177534073029
h2 = 4354685564936845355;  h3 = -6534734903238641935
h4 = 5840696475078001361;  h5 = -7276294671716946913
h6 = 2270897969802886507;  h7 = 6620516959819538809
sha512(block512abc, 16)(h0, h1, h2, h3, h4, h5, h6, h7)

fmt.print('sha512-abc=')
fmt.print-hex64(h0); fmt.print-hex64(h1); fmt.print-hex64(h2); fmt.print-hex64(h3)
fmt.print-hex64(h4); fmt.print-hex64(h5); fmt.print-hex64(h6); fmt.print-hex64(h7)
fmt.print('')

// ═══════════════════════════════════════════
// AES-128（NIST test vector）
// ═══════════════════════════════════════════

aes-key = '\x2b\x7e\x15\x16\x28\xae\xd2\xa6\xab\xf7\x15\x88\x09\xcf\x4f\x3c'
aes-plain = '\x6b\xc1\xbe\xe2\x2e\x40\x9f\x96\xe9\x3d\x7e\x11\x73\x93\x17\x2a'

aes-out = '\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00'
aes-128-enc(aes-plain, 16, aes-key)(aes-out)

fmt.print('aes-enc=')
i = 0
for i < 16 {
    fmt.print-hex8(aes-out[i] & 255)
    i = i + 1
}
fmt.print('')

aes-dec = '\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00'
aes-128-dec(aes-out, 16, aes-key)(aes-dec)

fmt.print('aes-dec=')
i = 0
for i < 16 {
    fmt.print-hex8(aes-dec[i] & 255)
    i = i + 1
}
fmt.print('')

// ═══════════════════════════════════════════
// DES
// ═══════════════════════════════════════════

des-key = '\x13\x34\x57\x79\x9b\xbc\xdf\xf1'
des-plain = '\x01\x23\x45\x67\x89\xab\xcd\xef'

des-out = '\x00\x00\x00\x00\x00\x00\x00\x00'
des-enc(des-plain, 8, des-key)(des-out)

fmt.print('des-enc=')
i = 0
for i < 8 {
    fmt.print-hex8(des-out[i] & 255)
    i = i + 1
}
fmt.print('')

des-dec = '\x00\x00\x00\x00\x00\x00\x00\x00'
des-dec(des-out, 8, des-key)(des-dec)

fmt.print('des-dec=')
i = 0
for i < 8 {
    fmt.print-hex8(des-dec[i] & 255)
    i = i + 1
}
fmt.print('')

// ═══════════════════════════════════════════
// 輔助函數
// ═══════════════════════════════════════════

make-str-16()(s str) {
    s = '                '
}
