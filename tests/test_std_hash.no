// ═══════════════════════════════════════════

make-str-16(block1empty)
block1empty[0] = 2147483648  // 0x80000000
i = 1
for i < 16 {
    block1empty[i] = 0
    i = i + 1
}

h0 = 1732584193; h1 = 4023233417; h2 = 2562383102; h3 = 271733878; h4 = 3285377520
sha1(block1empty, 16)(h0, h1, h2, h3, h4)

fmt.print('sha1-empty=')
fmt.print-hex32(h0); fmt.print-hex32(h1); fmt.print-hex32(h2); fmt.print-hex32(h3)
fmt.print-hex32(h4)
fmt.println('')

