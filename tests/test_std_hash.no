// ═══════════════════════════════════════════
// SHA-1（完整哈希："hello"）
// ═══════════════════════════════════════════

make-str-16(block1hello)
block1hello[0] = 1751477356  // 0x68656C6C "hell"
block1hello[1] = 1870659584  // 0x6F800000 "o" + 0x80
i = 2
for i < 15 {
    block1hello[i] = 0
    i = i + 1
}
block1hello[15] = 40  // 5*8 bits

h0 = 1732584193; h1 = 4023233417; h2 = 2562383102; h3 = 271733878; h4 = 3285377520
sha1(block1hello, 16)(h0, h1, h2, h3, h4)

fmt.print('sha1("hello")=')
fmt.print-hex32(h0); fmt.print-hex32(h1); fmt.print-hex32(h2); fmt.print-hex32(h3)
fmt.print-hex32(h4)
fmt.println('')

// ═══════════════════════════════════════════
// SHA-1（完整哈希："The quick brown fox..."）
// ═══════════════════════════════════════════

make-str-16(block1fox)
block1fox[0] = 1416125728   // 0x54686520 "The "
block1fox[1] = 1902461283   // 0x71756963 "quic"
block1fox[2] = 1796563570   // 0x6B206272 "k br"
block1fox[3] = 1869449760   // 0x6F776E20 "own "
block1fox[4] = 1718777888   // 0x666F7820 "fox "
block1fox[5] = 1785762160   // 0x6A756D70 "jump"
block1fox[6] = 1931505526   // 0x73206F76 "s ov"
block1fox[7] = 1701675124   // 0x65722074 "er t"
block1fox[8] = 1751479916   // 0x6865206C "he l"
block1fox[9] = 1635014944   // 0x617A7920 "azy "
block1fox[10] = 1685735296  // 0x646F6780 "dog" + 0x80
i = 11
for i < 15 {
    block1fox[i] = 0
    i = i + 1
}
block1fox[15] = 344  // 43*8 bits

h0 = 1732584193; h1 = 4023233417; h2 = 2562383102; h3 = 271733878; h4 = 3285377520
sha1(block1fox, 16)(h0, h1, h2, h3, h4)

fmt.print('sha1("fox")=')
fmt.print-hex32(h0); fmt.print-hex32(h1); fmt.print-hex32(h2); fmt.print-hex32(h3)
fmt.print-hex32(h4)
fmt.println('')

