// ═══════════════════════════════════════════
// AES-128（NIST test vector）
// ═══════════════════════════════════════════

aes-key = '\x2b\x7e\x15\x16\x28\xae\xd2\xa6\xab\xf7\x15\x88\x09\xcf\x4f\x3c'
aes-plain = '\x6b\xc1\xbe\xe2\x2e\x40\x9f\x96\xe9\x3d\x7e\x11\x73\x93\x17\x2a'

aes-out = '\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00'
aes-128-enc(aes-plain, 16, aes-key)(aes-out)

fmt.print('aes-enc=')
i = 0
for i < 16 {
    fmt.print-hex8(aes-out[i] & 255)
    i = i + 1
}
fmt.println('')

aes-dec = '\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00'
aes-128-dec(aes-out, 16, aes-key)(aes-dec)

fmt.print('aes-dec=')
i = 0
for i < 16 {
    fmt.print-hex8(aes-dec[i] & 255)
    i = i + 1
}
fmt.println('')

// ═══════════════════════════════════════════
// DES
// ═══════════════════════════════════════════

des-key = '\x13\x34\x57\x79\x9b\xbc\xdf\xf1'
des-plain = '\x01\x23\x45\x67\x89\xab\xcd\xef'

des-out = '\x00\x00\x00\x00\x00\x00\x00\x00'
des-enc(des-plain, 8, des-key)(des-out)

fmt.print('des-enc=')
i = 0
for i < 8 {
    fmt.print-hex8(des-out[i] & 255)
    i = i + 1
}
fmt.println('')

des-dec = '\x00\x00\x00\x00\x00\x00\x00\x00'
des-dec(des-out, 8, des-key)(des-dec)

fmt.print('des-dec=')
i = 0
for i < 8 {
    fmt.print-hex8(des-dec[i] & 255)
    i = i + 1
}
fmt.println('')

