// SHA-512（空字串填充區塊）
// ═══════════════════════════════════════════

make-str-16(block512empty)
block512empty[0] = 1 << 63  // 0x8000000000000000 (signed i64 min)
i = 1
for i < 16 {
    block512empty[i] = 0
    i = i + 1
}

h0 = 7640891576956012808;  h1 = -4942790177534073029
h2 = 4354685564936845355;  h3 = -6534734903238641935
