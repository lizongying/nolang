// test_std_hash.no — 標準庫 hash 模組測試
//
// 輸出 KEY=VALUE 格式，與 tests/compare/compare.go 一致。
// 執行：nolang run tests/test_std_hash.no > tests/nolang-output.txt
// 比對：diff tests/compare/go-output.txt tests/nolang-output.txt

# std/hash/crc-32
# std/hash/fnv-1a-32
# std/hash/md5
# std/hash/sha1
# std/hash/sha256
# std/hash/sha512
# std/hash/aes-128-enc
# std/hash/aes-128-dec
# std/hash/des-enc
# std/hash/des-dec
# std/hash/rand
# std/hash/rand-str

// ═══════════════════════════════════════════
// CRC32
// ═══════════════════════════════════════════

// crc32("")=00000000
crc-32('', 0)(h)
fmt.print('crc32("")=')
fmt.print-hex32(h)
fmt.println('')

// crc32("hello")=3610a686
crc-32('hello', 5)(h)
fmt.print('crc32("hello")=')
fmt.print-hex32(h)
fmt.println('')

// crc32("fox")=414fa339
s = 'The quick brown fox jumps over the lazy dog'
crc-32(s, 43)(h)
fmt.print('crc32("fox")=')
fmt.print-hex32(h)
fmt.println('')

// ═══════════════════════════════════════════
// FNV-1a-32
// ═══════════════════════════════════════════

// fnv1a32("")=811c9dc5
fnv-1a-32('', 0)(h)
fmt.print('fnv1a32("")=')
fmt.print-hex32(h)
fmt.println('')

// fnv1a32("hello")=4f9f2cab
fnv-1a-32('hello', 5)(h)
fmt.print('fnv1a32("hello")=')
fmt.print-hex32(h)
fmt.println('')

// fnv1a32("fox")=048fff90
fnv-1a-32(s, 43)(h)
fmt.print('fnv1a32("fox")=')
fmt.print-hex32(h)
fmt.println('')

// ═══════════════════════════════════════════
// MD5
// ═══════════════════════════════════════════

md5-out = '\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00'

// md5("")=d41d8cd98f00b204e9800998ecf8427e
md5('')(md5-out)
fmt.print('md5("")=')
i = 0
for i < 16 {
    fmt.print-hex8(md5-out[i] & 255)
    i = i + 1
}
fmt.println('')

// md5("hello")=5d41402abc4b2a76b9719d911017c592
md5('hello')(md5-out)
fmt.print('md5("hello")=')
i = 0
for i < 16 {
    fmt.print-hex8(md5-out[i] & 255)
    i = i + 1
}
fmt.println('')

// md5("fox")=9e107d9d372bb6826bd81d3542a419d6
md5(s)(md5-out)
fmt.print('md5("fox")=')
i = 0
for i < 16 {
    fmt.print-hex8(md5-out[i] & 255)
    i = i + 1
}
fmt.println('')

// ═══════════════════════════════════════════
// SHA-1（zero block 壓縮測試）
// ═══════════════════════════════════════════

make-str-16(block1)
i = 0
for i < 16 {
    block1[i] = 0
    i = i + 1
}

// sha1-zero-block=67452301efcdab8998badcfe10325476c3d2e1f0
h0 = 1732584193; h1 = 4023233417; h2 = 2562383102; h3 = 271733878; h4 = 3285377520
sha1(block1, 16)(h0, h1, h2, h3, h4)

fmt.print('sha1-zero-block=')
fmt.print-hex32(h0); fmt.print-hex32(h1); fmt.print-hex32(h2); fmt.print-hex32(h3)
fmt.print-hex32(h4)
fmt.println('')

// ═══════════════════════════════════════════
