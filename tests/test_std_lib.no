// test_std_lib.no — 標準庫功能展示
//
// 展示 src/std/ 中各模組的基本用法。

// ═══════════════════════════════════════════
// number — 數字操作
// ═══════════════════════════════════════════

demo-number() {
    max(10, 20, r)
    println-i64(r)

    min(10, 20, r)
    println-i64(r)

    abs-i64(-42, r)
    println-i64(r)

    gcd(12, 18, r)
    println-i64(r)

    even(7, yes)
    println-i64(yes)

    odd(7, yes)
    println-i64(yes)
}

demo-number()

// ═══════════════════════════════════════════
// arr — 陣列操作
// ═══════════════════════════════════════════

demo-arr() {
    // arr-fill
    data [4] = [1, 2, 3, 4]
    arr-fill(data, 4, 42)
    println-i64(data[0])
    println-i64(data[3])
}

demo-arr()

// ═══════════════════════════════════════════
// demo done
// ═══════════════════════════════════════════

println-i64(0)
