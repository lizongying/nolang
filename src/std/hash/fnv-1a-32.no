// fnv-1a — FNV-1a 非加密哈希（32bit）
//
// 快速、簡單的非加密哈希，適用於哈希表等場景。
//
// 用法：
//   h = 0
//   fnv-1a-32('hello', 5, h)

// fnv-1a-32: 32-bit FNV-1a 哈希
// s: 輸入字串, n: 字串長度, h: 輸出哈希值
fnv-1a-32 = (s str, n i64, h i64) {
    h = 2166136261
    i = 0
    i < n: {
        h = h ^ s[i]
        h = h * 16777619
        i = i + 1
    }
}