// x509 — X.509 憑證 DER 解析工具
//
// 提供 DER 編碼的 X.509 憑證基本解析：
//   - DER TLV（Tag-Length-Value）底層解析
//   - 憑證結構導航（TBSCertificate、序號、公鑰）
//   - RSA 公鑰指數提取
//   - SHA-256 憑證指紋計算
//
// 用法：
//   cert = '(DER bytes)'; n = len(cert)
//
//   // 計算憑證指紋
//   h0=1779033703; h1=3144134277; h2=1013904242; h3=2773480762
//   h4=1359893119; h5=2600822924; h6=528734635;  h7=1541459225
//   x509-fingerprint(cert, n, h0, h1, h2, h3, h4, h5, h6, h7)
//
//   // 提取 RSA 公鑰指數
//   e = 0
//   x509-rsa-e(cert, n, e)

// ─── DER TLV 底層解析 ─────────────────────────────────

// der-tag: 讀取 DER 標籤位元組
// data: DER 編碼資料, pos: 位置
// tag: 輸出標籤值
der-tag = (data []byte, pos i64) (tag i64) {
    tag = data[pos] & 255
}

// der-len: 解碼 DER 長度
// data: DER 編碼資料, pos: 位置（指向長度位元組）
// len: 輸出長度值, adv: 輸出消耗的位元組數（1 或更多）
der-len = (data []byte, pos i64) (len i64, adv i64) {
    b = data[pos] & 255
    if b & 128 == 0 {
        // 短格式：長度 = b (0-127)
        len = b
        adv = 1
    } else {
        // 長格式：後續 (b & 0x7F) 個位元組編碼長度
        n = b & 127
        len = 0
        i = 0
        i < n: {
            len = (len << 8) | (data[pos + 1 + i] & 255)
            i = i + 1
        }
        adv = 1 + n
    }
}

// der-skip: 跳過一個 DER TLV 元素
// data: DER 編碼資料, n: 資料總長度
// pos: 目前位置（指向標籤位元組）
// next: 輸出下一個元素的位置
der-skip = (data []byte, n i64, pos i64) (next i64) {
    // 跳過標籤（1 位元組）
    p = pos + 1
    l, adv = der-len(data, p)
    p = p + adv

    // 跳過值
    next = p + l
}

// ─── X.509 結構導航 ─────────────────────────────────

// x509-tbs-range: 找出 TBSCertificate 的位元組範圍
// data: DER 編碼憑證, n: 總長度
// start: 輸出 TBS 起始位置（含 SEQUENCE 標籤）
// end: 輸出 TBS 結束位置（不含，即下個元素的起始）
x509-tbs-range = (data []byte, n i64) (start i64, end i64) {
    // 驗證外層 SEQUENCE
    tag = data[0] & 255
    if tag != 48 {
        start = 0
        end = 0
        return
    }
    outer-len, adv = der-len(data, 1)

    // 內層 SEQUENCE（TBSCertificate）從標籤開始
    start = 1 + adv
    inner-tag = der-tag(data, start)
    if inner-tag != 48 {
        start = 0
        end = 0
        return
    }
    end = der-skip(data, n, start)
}

// x509-serial: 提取憑證序號（若可放入 i64）
// data: DER 編碼憑證, n: 總長度
// serial: 輸出序號（0 表示無法提取）
x509-serial = (data []byte, n i64, serial i64) {
    tbs-start, tbs-end = x509-tbs-range(data, n)
    if tbs-start == 0 {
        serial = 0
        return
    }

    // 跳過 TBS SEQUENCE 標籤 + 長度，進入內容
    p = tbs-start + 1
    tbs-len, adv = der-len(data, p)
    p = p + adv

    // 檢查是否為 [0] EXPLICIT（版本，v2/v3 才有）
    // 現在應該是 INTEGER（序號）
    t = der-tag(data, p)
    if t == 160 {
        // 跳過 [0] EXPLICIT 元素
        p = der-skip(data, n, p)
    }
    t = der-tag(data, p)
    if t != 2 {
        serial = 0
        return
    }
    int-len, adv = der-len(data, p + 1)
    if int-len > 8 {
        // 序號太大，無法放入 i64
        serial = 0
        return
    }

    // 讀取序號值
    val = 0
    i = 0
    i < int-len: {
        val = (val << 8) | (data[p + 1 + adv + i] & 255)
        i = i + 1
    }
    serial = val
}

// x509-rsa-e: 提取 RSA 公鑰指數（通常為 65537）
// data: DER 編碼憑證, n: 總長度
// e: 輸出指數值（0 表示非 RSA 或解析失敗）
x509-rsa-e = (data []byte, n i64, e i64) {
    tbs-start, tbs-end = x509-tbs-range(data, n)
    if tbs-start == 0 {
        e = 0
        return
    }

    // 進入 TBS 內容（跳過 TBS SEQUENCE 標籤 + 長度）
    p = tbs-start + 1
    tbs-len, adv = der-len(data, p)
    p = p + adv

    // 步驟 1：可選——跳過 [0] EXPLICIT（版本，tag 160，僅 v2/v3）
    t = der-tag(data, p)
    if t == 160 {
        p = der-skip(data, n, p)
    }

    // 步驟 2：跳過 INTEGER（serialNumber，tag 2）
    p = der-skip(data, n, p)

    // 步驟 3：跳過 SEQUENCE（signature algorithm identifier，tag 48）
    p = der-skip(data, n, p)

    // 步驟 4：跳過 SEQUENCE（issuer，tag 48）
    p = der-skip(data, n, p)

    // 步驟 5：跳過 SEQUENCE（validity，tag 48）
    p = der-skip(data, n, p)

    // 步驟 6：跳過 SEQUENCE（subject，tag 48）
    p = der-skip(data, n, p)

    // 現在 p 指向 SubjectPublicKeyInfo（SEQUENCE，tag 48）

    // 步驟 7：進入 SPKI 內容（跳過 SPKI SEQUENCE 標籤 + 長度）
    p = p + 1
    spki-len, adv = der-len(data, p)
    p = p + adv

    // 步驟 8：跳過 SEQUENCE（AlgorithmIdentifier，tag 48）
    p = der-skip(data, n, p)

    // 步驟 9：讀取 BIT STRING（subjectPublicKey，tag 3）
    t = der-tag(data, p)
    if t != 3 {
        e = 0
        return
    }
    bit-len, adv = der-len(data, p + 1)

    // BIT STRING 內容：跳過未使用位元組（1 位元組），然後是 RSAPublicKey
    bit-pos = p + 1 + adv + 1  // 跳過標籤+長度+未使用位元數位元組

    // 步驟 10：RSAPublicKey（SEQUENCE，tag 48）
    t = der-tag(data, bit-pos)
    if t != 48 {
        e = 0
        return
    }
    rsa-start = der-skip(data, n, bit-pos)

    // rsa-start 指向 RSAPublicKey 內容

    // RSAPublicKey 內容：
    //   INTEGER (modulus n)
    //   INTEGER (exponent e)

    // 步驟 11：跳過 modulus INTEGER（tag 2）
    rsa-start = der-skip(data, n, rsa-start)

    // 步驟 12：讀取 exponent INTEGER（tag 2）
    t = der-tag(data, rsa-start)
    if t != 2 {
        e = 0
        return
    }
    exp-len, adv = der-len(data, rsa-start - p + 1)
    if exp-len > 8 {
        e = 0
        return
    }
    val = 0
    i = 0
    i < exp-len: {
        val = (val << 8) | (data[rsa-start + 1 + adv + i] & 255)
        i = i + 1
    }
    e = val
}

// ─── SHA-256 憑證指紋 ─────────────────────────────────

// x509-fingerprint: 計算 X.509 憑證的 SHA-256 指紋
// 即 TBSCertificate 的 SHA-256 哈希值。
// data: DER 編碼憑證, n: 總長度
// h0..h7: 輸入必須為 SHA-256 初始值，輸出為 256-bit 指紋
//
// 本函數處理完整的 SHA-256 填充和位元組→字轉換。

x509-fingerprint = (data []byte, n i64) (h0 i64, h1 i64, h2 i64, h3 i64, h4 i64, h5 i64, h6 i64, h7 i64) {
    tbs-start, tbs-end = x509-tbs-range(data, n)
    if tbs-start == 0 {
        return
    }
    mask = 4294967295

    // TBS 長度（位元組）
    tbs-len = tbs-end - tbs-start

    // SHA-256 填充：
    // 1. 附加 0x80
    // 2. 附加 0x00 直到 (tbs-len + 1 + k + 8) % 64 == 0
    // 3. 附加 64-bit big-endian 位元長度
    pad-len = tbs-len + 1 + 8

    // 無條件進位到 64 的倍數
    rem = pad-len % 64
    if rem != 0 {
        pad-len = pad-len + 64 - rem
    }

    // padded 訊息的總區塊數
    num-blocks = pad-len / 64

    // 給 sha256 的 16 字工作區（每個區塊重設）
    w0 = 0; w1 = 0; w2 = 0; w3 = 0; w4 = 0; w5 = 0; w6 = 0; w7 = 0
    w8 = 0; w9 = 0; w10 = 0; w11 = 0; w12 = 0; w13 = 0; w14 = 0; w15 = 0
    bidx = 0
    bidx < num-blocks

    // 將當前 64 位元組區塊轉換為 16 個 32-bit big-endian 字
    off = bidx * 64

    // 辨認我們在填充後的哪個區段：
    //   [0, tbs-len)：原始 TBS 位元組
    //   [tbs-len]：0x80 填充位元組
    //   (tbs-len, pad-len-8)：0x00 填充
    //   [pad-len-8, pad-len)：64-bit 位元長度（大端序）

    wi = 0  // suppress unused warning
    wi < 16: {
        boff = off + wi * 4  // 此字在 padded 訊息中的位元組偏移

        // 組裝 4 個位元組 → 32-bit 大端字
        b0 = 0
        b1 = 0
        b2 = 0  // 0x80 已放在 b0 或 b1
        b3 = 0

        // 位元組 0
        if boff < tbs-len {
            b0 = data[tbs-start + boff] & 255
        } elif boff == tbs-len {
            b0 = 128  // 0x80
        } elif boff >= pad-len - 8 {
            // 長度欄位（64-bit big-endian，在位元組偏移 pad-len-8 開始）
            bit-len = tbs-len * 8
            len-byte-idx = boff - (pad-len - 8)
            if len-byte-idx == 0 {
                b0 = (bit-len >> 56) & 255
            } elif len-byte-idx == 1 {
                b0 = (bit-len >> 48) & 255
            } elif len-byte-idx == 2 {
                b0 = (bit-len >> 40) & 255
            } elif len-byte-idx == 3 {
                b0 = (bit-len >> 32) & 255
            } elif len-byte-idx == 4 {
                b0 = (bit-len >> 24) & 255
            } elif len-byte-idx == 5 {
                b0 = (bit-len >> 16) & 255
            } elif len-byte-idx == 6 {
                b0 = (bit-len >> 8) & 255
            } else {
                b0 = bit-len & 255
            }
        }

        // 位元組 1
        if boff + 1 < tbs-len {
            b1 = data[tbs-start + boff + 1] & 255
        } elif boff + 1 == tbs-len {
            b1 = 128  // 0x80
        } elif boff + 1 >= pad-len - 8 {
            bit-len = tbs-len * 8
            len-byte-idx = (boff + 1) - (pad-len - 8)
            if len-byte-idx == 0 {
                b1 = (bit-len >> 56) & 255
            } elif len-byte-idx == 1 {
                b1 = (bit-len >> 48) & 255
            } elif len-byte-idx == 2 {
                b1 = (bit-len >> 40) & 255
            } elif len-byte-idx == 3 {
                b1 = (bit-len >> 32) & 255
            } elif len-byte-idx == 4 {
                b1 = (bit-len >> 24) & 255
            } elif len-byte-idx == 5 {
                b1 = (bit-len >> 16) & 255
            } elif len-byte-idx == 6 {
                b1 = (bit-len >> 8) & 255
            } else {
                b1 = bit-len & 255
            }
        }

        // 位元組 2
        if boff + 2 < tbs-len {
            b2 = data[tbs-start + boff + 2] & 255
        } elif boff + 2 == tbs-len {
            b2 = 0
            // 實際上 0x80 只需要出現一次。如果 boff+2 == tbs-len，
            // 表示 0x80 已經在前面的位元組放過了
        } elif boff + 2 >= pad-len - 8 {
            bit-len = tbs-len * 8
            len-byte-idx = (boff + 2) - (pad-len - 8)
            if len-byte-idx == 0 {
                b2 = (bit-len >> 56) & 255
            } elif len-byte-idx == 1 {
                b2 = (bit-len >> 48) & 255
            } elif len-byte-idx == 2 {
                b2 = (bit-len >> 40) & 255
            } elif len-byte-idx == 3 {
                b2 = (bit-len >> 32) & 255
            } elif len-byte-idx == 4 {
                b2 = (bit-len >> 24) & 255
            } elif len-byte-idx == 5 {
                b2 = (bit-len >> 16) & 255
            } elif len-byte-idx == 6 {
                b2 = (bit-len >> 8) & 255
            } else {
                b2 = bit-len & 255
            }
        }

        // 位元組 3
        if boff + 3 < tbs-len {
            b3 = data[tbs-start + boff + 3] & 255
        } elif boff + 3 == tbs-len {
            b3 = 128  // 只有當 0x80 剛好在這位置
        } elif boff + 3 >= pad-len - 8 {
            bit-len = tbs-len * 8
            len-byte-idx = (boff + 3) - (pad-len - 8)
            if len-byte-idx == 0 {
                b3 = (bit-len >> 56) & 255
            } elif len-byte-idx == 1 {
                b3 = (bit-len >> 48) & 255
            } elif len-byte-idx == 2 {
                b3 = (bit-len >> 40) & 255
            } elif len-byte-idx == 3 {
                b3 = (bit-len >> 32) & 255
            } elif len-byte-idx == 4 {
                b3 = (bit-len >> 24) & 255
            } elif len-byte-idx == 5 {
                b3 = (bit-len >> 16) & 255
            } elif len-byte-idx == 6 {
                b3 = (bit-len >> 8) & 255
            } else {
                b3 = bit-len & 255
            }
        }
        word = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        word = word & mask
        if wi == 0 {
            w0 = word
        } elif wi == 1 {
            w1 = word
        } elif wi == 2 {
            w2 = word
        } elif wi == 3 {
            w3 = word
        } elif wi == 4 {
            w4 = word
        } elif wi == 5 {
            w5 = word
        } elif wi == 6 {
            w6 = word
        } elif wi == 7 {
            w7 = word
        } elif wi == 8 {
            w8 = word
        } elif wi == 9 {
            w9 = word
        } elif wi == 10 {
            w10 = word
        } elif wi == 11 {
            w11 = word
        } elif wi == 12 {
            w12 = word
        } elif wi == 13 {
            w13 = word
        } elif wi == 14 {
            w14 = word
        } else {
            w15 = word
        }
        wi = wi + 1
    }
    h0, h1, h2, h3, h4, h5, h6, h7 = sha256-compress(w0, w1, w2, w3, w4, w5, w6, w7, w8, w9, w10, w11, w12, w13, w14, w15)
    bidx = bidx + 1
}

// 找到 TBSCertificate 範圍
// ─── SHA-256 壓縮函數（內建，直接用 w0..w15 變數）───

// sha256-compress: SHA-256 單區塊壓縮
// w0..w15: 16 個 32-bit 大端字（512-bit 區塊）
// h0..h7: 輸入/輸出 256-bit 哈希狀態
sha256-compress = (w0 i64, w1 i64, w2 i64, w3 i64, w4 i64, w5 i64, w6 i64, w7 i64, w8 i64, w9 i64, w10 i64, w11 i64, w12 i64, w13 i64, w14 i64, w15 i64) (h0 i64, h1 i64, h2 i64, h3 i64, h4 i64, h5 i64, h6 i64, h7 i64) {
    mask = 4294967295
    a = h0; b = h1; c = h2; d = h3; e = h4; f = h5; g = h6; h = h7

    // 第 0 輪 (K0 = 0x428A2F98)

    s1 = ((e >> 6) | (e << 26)) & mask; s1 = s1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    ch = (e & f) ^ ((mask ^ e) & g)
    s0 = ((a >> 2) | (a << 30)) & mask; s0 = s0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    maj = (a & b) ^ (a & c) ^ (b & c)
    t1 = (h + s1 + ch + 1116352408 + w0) & mask
    t2 = (s0 + maj) & mask
    h = g; g = f; f = e; e = (d + t1) & mask
    d = c; c = b; b = a; a = (t1 + t2) & mask

    // 第 1 輪 (K1 = 0x71374491)
    s1 = ((e >> 6) | (e << 26)) & mask; s1 = s1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    ch = (e & f) ^ ((mask ^ e) & g)
    s0 = ((a >> 2) | (a << 30)) & mask; s0 = s0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    maj = (a & b) ^ (a & c) ^ (b & c)
    t1 = (h + s1 + ch + 1899447441 + w1) & mask
    t2 = (s0 + maj) & mask
    h = g; g = f; f = e; e = (d + t1) & mask
    d = c; c = b; b = a; a = (t1 + t2) & mask

    // 第 2 輪 (K2 = 0xB5C0FBCF)
    s1 = ((e >> 6) | (e << 26)) & mask; s1 = s1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    ch = (e & f) ^ ((mask ^ e) & g)
    s0 = ((a >> 2) | (a << 30)) & mask; s0 = s0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    maj = (a & b) ^ (a & c) ^ (b & c)
    t1 = (h + s1 + ch + 3049323471 + w2) & mask
    t2 = (s0 + maj) & mask
    h = g; g = f; f = e; e = (d + t1) & mask
    d = c; c = b; b = a; a = (t1 + t2) & mask

    // 第 3 輪 (K3 = 0xE9B5DBA5)
    s1 = ((e >> 6) | (e << 26)) & mask; s1 = s1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    ch = (e & f) ^ ((mask ^ e) & g)
    s0 = ((a >> 2) | (a << 30)) & mask; s0 = s0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    maj = (a & b) ^ (a & c) ^ (b & c)
    t1 = (h + s1 + ch + 3921009573 + w3) & mask
    t2 = (s0 + maj) & mask
    h = g; g = f; f = e; e = (d + t1) & mask
    d = c; c = b; b = a; a = (t1 + t2) & mask

    // 第 4 輪 (K4 = 0x3956C25B)
    s1 = ((e >> 6) | (e << 26)) & mask; s1 = s1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    ch = (e & f) ^ ((mask ^ e) & g)
    s0 = ((a >> 2) | (a << 30)) & mask; s0 = s0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    maj = (a & b) ^ (a & c) ^ (b & c)
    t1 = (h + s1 + ch + 961987163 + w4) & mask
    t2 = (s0 + maj) & mask
    h = g; g = f; f = e; e = (d + t1) & mask
    d = c; c = b; b = a; a = (t1 + t2) & mask

    // 第 5 輪 (K5 = 0x59F111F1)
    s1 = ((e >> 6) | (e << 26)) & mask; s1 = s1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    ch = (e & f) ^ ((mask ^ e) & g)
    s0 = ((a >> 2) | (a << 30)) & mask; s0 = s0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    maj = (a & b) ^ (a & c) ^ (b & c)
    t1 = (h + s1 + ch + 1508970993 + w5) & mask
    t2 = (s0 + maj) & mask
    h = g; g = f; f = e; e = (d + t1) & mask
    d = c; c = b; b = a; a = (t1 + t2) & mask

    // 第 6 輪 (K6 = 0x923F82A4)
    s1 = ((e >> 6) | (e << 26)) & mask; s1 = s1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    ch = (e & f) ^ ((mask ^ e) & g)
    s0 = ((a >> 2) | (a << 30)) & mask; s0 = s0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    maj = (a & b) ^ (a & c) ^ (b & c)
    t1 = (h + s1 + ch + 2453635748 + w6) & mask
    t2 = (s0 + maj) & mask
    h = g; g = f; f = e; e = (d + t1) & mask
    d = c; c = b; b = a; a = (t1 + t2) & mask

    // 第 7 輪 (K7 = 0xAB1C5ED5)
    s1 = ((e >> 6) | (e << 26)) & mask; s1 = s1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    ch = (e & f) ^ ((mask ^ e) & g)
    s0 = ((a >> 2) | (a << 30)) & mask; s0 = s0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    maj = (a & b) ^ (a & c) ^ (b & c)
    t1 = (h + s1 + ch + 2870763221 + w7) & mask
    t2 = (s0 + maj) & mask
    h = g; g = f; f = e; e = (d + t1) & mask
    d = c; c = b; b = a; a = (t1 + t2) & mask

    // 第 8 輪 (K8 = 0xD807AA98)
