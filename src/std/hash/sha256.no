// sha256 — SHA-256 安全哈希算法（256-bit）
//
// 處理一個 512-bit（16 字）區塊。
// 多區塊訊息需由呼叫者自行填充和累加。
//
// 用法：
//   h0 = 1779033703; h1 = 3144134277; h2 = 1013904242; h3 = 2773480762
//   h4 = 1359893119; h5 = 2600822924; h6 = 528734635;  h7 = 1541459225
//   sha256(block, 16, h0, h1, h2, h3, h4, h5, h6, h7)

// sha256: 處理一個 512-bit 區塊
// s: 16 個 32-bit 字 (big-endian)
// n: 固定 16
// h0..h7: 輸入/輸出 256-bit 哈希狀態
sha256 = (s str, n i64, h0 i64, h1 i64, h2 i64, h3 i64, h4 i64, h5 i64, h6 i64, h7 i64) {
    MASK = 4294967295

    // 初始狀態
    a = h0; b = h1; c = h2; d = h3; e = h4; f = h5; g = h6; h = h7

    // ---- 第 0 輪 (K = 0x428A2F98 = 1116352408) ----
    S1 = ((e >> 6) | (e << 26)) & MASK; S1 = S1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    Ch = (e & f) ^ ((MASK ^ e) & g)
    S0 = ((a >> 2) | (a << 30)) & MASK; S0 = S0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    Maj = (a & b) ^ (a & c) ^ (b & c)
    T1 = (h + S1 + Ch + 1116352408 + s[0]) & MASK
    T2 = (S0 + Maj) & MASK
    h = g; g = f; f = e; e = (d + T1) & MASK
    d = c; c = b; b = a; a = (T1 + T2) & MASK

    // 第 1 輪 (K = 0x71374491 = 1899447441)
    S1 = ((e >> 6) | (e << 26)) & MASK; S1 = S1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    Ch = (e & f) ^ ((MASK ^ e) & g)
    S0 = ((a >> 2) | (a << 30)) & MASK; S0 = S0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    Maj = (a & b) ^ (a & c) ^ (b & c)
    T1 = (h + S1 + Ch + 1899447441 + s[1]) & MASK
    T2 = (S0 + Maj) & MASK
    h = g; g = f; f = e; e = (d + T1) & MASK
    d = c; c = b; b = a; a = (T1 + T2) & MASK

    // 第 2 輪 (K = 0xB5C0FBCF = 3049323471)
    S1 = ((e >> 6) | (e << 26)) & MASK; S1 = S1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
    Ch = (e & f) ^ ((MASK ^ e) & g)
    S0 = ((a >> 2) | (a << 30)) & MASK; S0 = S0 ^ ((a >> 13) | (a << 19)) ^ ((a >> 22) | (a << 10))
    Maj = (a & b) ^ (a & c) ^ (b & c)
    T1 = (h + S1 + Ch + 3049323471 + s[2]) & MASK
    T2 = (S0 + Maj) & MASK
    h = g; g = f; f = e; e = (d + T1) & MASK
    d = c; c = b; b = a; a = (T1 + T2) & MASK

    // 第 3 輪 (K = 0xE9B5DBA5 = 3921009573)
    S1 = ((e >> 6) | (e << 26)) & MASK; S1 = S1 ^ ((e >> 11) | (e << 21)) ^ ((e >> 25) | (e << 7))
