    // ---- 第 16-63 輪：擴展訊息排程 + 壓縮 ----
    // 預計算所有 W[16..63]
    w0 = s[0]; w1 = s[1]; w2 = s[2]; w3 = s[3]
    w4 = s[4]; w5 = s[5]; w6 = s[6]; w7 = s[7]
    w8 = s[8]; w9 = s[9]; w10 = s[10]; w11 = s[11]
    w12 = s[12]; w13 = s[13]; w14 = s[14]; w15 = s[15]

    // W[16]: σ1(w14) + w9 + σ0(w1) + w0
    s0_r7 = ((w1 >> 7) | (w1 << 25)) & MASK; s0_r18 = ((w1 >> 18) | (w1 << 14)) & MASK; s0_sh3 = w1 >> 3
    s0_w1 = s0_r7 ^ s0_r18 ^ s0_sh3
    s1_r17 = ((w14 >> 17) | (w14 << 15)) & MASK; s1_r19 = ((w14 >> 19) | (w14 << 13)) & MASK; s1_sh10 = w14 >> 10
    s1_w14 = s1_r17 ^ s1_r19 ^ s1_sh10
