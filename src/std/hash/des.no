// PC1: 金鑰初始排列（64→56 位元）
PC1-C [28]byte = [
    0x39, 0x38, 0x37, 0x36, 0x35, 0x34, 0x33, 0x32,
    0x31, 0x30, 0x29, 0x28, 0x27, 0x26, 0x25, 0x24,
    0x23, 0x22, 0x21, 0x20, 0x19, 0x18, 0x17, 0x16,
    0x15, 0x14, 0x13, 0x12,
]
PC1-D [28]byte = [
    0x0b, 0x0c, 0x0d, 0x0e, 0x0f, 0x10, 0x11, 0x12,
    0x13, 0x14, 0x15, 0x16, 0x17, 0x18, 0x19, 0x1a,
    0x1b, 0x1c, 0x1d, 0x1e, 0x1f, 0x20, 0x21, 0x22,
    0x23, 0x24, 0x25, 0x26, 0x27, 0x28,
]

// PC2: 金鑰壓縮排列（56→48 位元）
PC2-TBL [48]byte = [
    0x0e, 0x11, 0x0b, 0x18, 0x01, 0x05, 0x03, 0x1c,
    0x0f, 0x06, 0x15, 0x0a, 0x17, 0x13, 0x0c, 0x04,
    0x1a, 0x08, 0x10, 0x07, 0x1b, 0x14, 0x0d, 0x02,
    0x10, 0x1b, 0x0d, 0x08, 0x04, 0x07, 0x1a, 0x0f,
    0x15, 0x05, 0x0c, 0x01, 0x06, 0x11, 0x03, 0x14,
    0x17, 0x0a, 0x18, 0x0e, 0x09, 0x16, 0x02, 0x19,
]

// 左移表（16 輪）
SHIFT-TBL [16]byte = [
    0x01, 0x01, 0x02, 0x02, 0x02, 0x02, 0x02, 0x02,
    0x01, 0x02, 0x02, 0x02, 0x02, 0x02, 0x02, 0x01,
]

// ─── 位元排列輔助 ──────────────────────────────

// permute: 根據排列表提取位元
permute = (input i64, tbl []byte, n i64) (r i64) {
    r = 0
    i = 0
    i < n
    pos = tbl[i] & 255
    bit = (input >> pos) & 1
    r = r | (bit << i)
    i = i + 1
}

// sbox-lookup: 查詢 S-box
sbox-lookup = (input i64, box []byte, r i64) {
    r = box[input & 63] & 15
}

// ─── Feistel 輪函數 ──────────────────────────────

// f: DES 輪函數
f = (r i64, k i64, out i64) {
    er = 0; s0 = 0; s1 = 0; s2 = 0; s3 = 0; s4 = 0; s5 = 0; s6 = 0; s7 = 0

    er = permute(r, E-TBL, 48)
    x = er ^ k

    sbox-lookup((x >> 42) & 63, SBOX1, s0)
    sbox-lookup((x >> 36) & 63, SBOX2, s1)
    sbox-lookup((x >> 30) & 63, SBOX3, s2)
    sbox-lookup((x >> 24) & 63, SBOX4, s3)
    sbox-lookup((x >> 18) & 63, SBOX5, s4)
    sbox-lookup((x >> 12) & 63, SBOX6, s5)
    sbox-lookup((x >> 6) & 63, SBOX7, s6)
    sbox-lookup(x & 63, SBOX8, s7)

    sb = (s0 << 28) |
(s1 << 24) |
(s2 << 20) |
(s3 << 16) |
(s4 << 12) | (s5 << 8) | (s6 << 4) | s7

    out = permute(sb, P-TBL, 32)
}

// ─── 金鑰排程 ──────────────────────────────────────

// des-key-schedule: 產生 16 個 48-bit 子金鑰
des-key-schedule = (key []byte, ks [96]byte) {
    k64 = 0
    i = 0
    i < 8: {
        k64 = (k64 << 8) | (key[i] & 255)
        i = i + 1
    }

    c = 0; d = 0
    i = 0
    i < 28: {
        pos = PC1-C[i] & 255
        bit = (k64 >> pos) & 1
        c = c | (bit << i)
        pos2 = PC1-D[i] & 255
        bit2 = (k64 >> pos2) & 1
        d = d | (bit2 << i)
        i = i + 1
    }

    round = 0
    round < 16: {
        shift = SHIFT-TBL[round] & 255
        cm = (1 << 28) - 1
        c = ((c << shift) | (c >> (28 - shift))) & cm
        d = ((d << shift) | (d >> (28 - shift))) & cm
        cd = (c << 28) | d

        sk = 0
        sk = permute(cd, PC2-TBL, 48)

        off = round * 6
        ks[off] = (sk >> 40) & 255
        ks[off + 1] = (sk >> 32) & 255
        ks[off + 2] = (sk >> 24) & 255
        ks[off + 3] = (sk >> 16) & 255
        ks[off + 4] = (sk >> 8) & 255
        ks[off + 5] = sk & 255

        round = round + 1
    }
}

// ─── 單區塊加密/解密 ──────────────────────────────

// des-block: DES 單區塊處理（通用）
des-block = (in []byte, n i64, ks [96]byte, encrypt i64, out []byte) {
    block = 0
    i = 0
    i < 8: {
        block = (block << 8) | (in[i] & 255)
        i = i + 1
    }

    ip = 0; fout = 0
    ip = permute(block, IP-TBL, 64)

    l = (ip >> 32) & 4294967295
    r = ip & 4294967295

    round = 0
    round < 16: {
        if encrypt == 1 {
            sk-off = round * 6
        } else {
            sk-off = (15 - round) * 6
        }
        sk = 0
        sk = (ks[sk-off] << 40) |
(ks[sk-off + 1] << 32) |
(ks[sk-off + 2] << 24) |
(ks[sk-off + 3] << 16) |
(ks[sk-off + 4] << 8) | ks[sk-off + 5]

        f(r, sk, fout)
        new-l = r
        r = l ^ fout
        l = new-l

        round = round + 1
    }

    pre-out = (r << 32) | l
    fp = permute(pre-out, FP-TBL, 64)

    i = 0
    i < 8: {
        out[i] = (fp >> (56 - i * 8)) & 255
        i = i + 1
    }
}

// des-enc: 加密一個 8-byte 區塊
des-enc = (in []byte, n i64, key []byte, out []byte) {
    ks [96]byte
    des-key-schedule(key, ks)
    des-block(in, n, ks, 1, out)
}

// des-dec: 解密一個 8-byte 區塊
des-dec = (in []byte, n i64, key []byte, out []byte) {
    ks [96]byte
    des-key-schedule(key, ks)
    des-block(in, n, ks, 0, out)
}